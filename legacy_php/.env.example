# GPS Payments - Environment Configuration
# Copy this file to .env and update values for your environment

# ============================================
# APPLICATION
# ============================================
APP_ENV=development
APP_URL=http://localhost/gpspayments
APP_NAME=GPS Payments - Member Association System

# ============================================
# DATABASE
# ============================================
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASS=
DB_NAME=gpspayments

# ============================================
# PAYMENT GATEWAYS
# ============================================
# Mobile Money / MOMO
MOMO_CALLBACK_SECRET=your_momo_callback_secret_here
MOMO_API_KEY=your_momo_api_key_here

# ============================================
# SMS GATEWAY
# ============================================
SMS_GATEWAY_URL=https://api.sms-provider.com/send
SMS_API_KEY=your_sms_api_key_here
SMS_SENDER_ID=GPS_PAYMENTS

# ============================================
# EMAIL
# ============================================
MAIL_DRIVER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_app_password
MAIL_FROM=noreply@gpspayments.local
MAIL_FROM_NAME=GPS Payments

# ============================================
# LOGGING
# ============================================
LOG_LEVEL=info
LOG_CHANNEL=file

# ============================================
# SESSION
# ============================================
SESSION_LIFETIME=1800

# ============================================
# SECURITY
# ============================================
ENCRYPTION_KEY=your_encryption_key_here
JWT_SECRET=your_jwt_secret_here
